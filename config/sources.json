{
  "arxiv": {
    "enabled": true,
    "max_results": 15,
    "delay_seconds": 3.2,
    "queries": [
      "cat:q-fin.*",
      "all:\"machine learning\" AND all:finance",
      "all:\"deep learning\" AND all:finance",
      "all:transformer AND all:finance",
      "all:\"reinforcement learning\" AND all:trading",
      "all:portfolio AND all:optimization",
      "all:\"market microstructure\"",
      "all:\"statistical arbitrage\""
    ]
  },
  "github": {
    "enabled": true,
    "max_results": 15,
    "queries": [
      "quant trading backtesting",
      "portfolio optimization finance",
      "market microstructure trading",
      "alpha factor research"
    ]
  },
  "rss": {
    "enabled": true,
    "max_results_per_feed": 10,
    "feeds": [
      {
        "name": "Reddit algotrading",
        "url": "https://www.reddit.com/r/algotrading/.rss",
        "source_type": "forum"
      },
      {
        "name": "Reddit quant",
        "url": "https://www.reddit.com/r/quant/.rss",
        "source_type": "forum"
      },
      {
        "name": "Quant StackExchange",
        "url": "https://quant.stackexchange.com/feeds",
        "source_type": "forum"
      }
    ]
  },
  "social_json": {
    "enabled": true,
    "paths": [
      "data/social_items.json"
    ]
  }
}
